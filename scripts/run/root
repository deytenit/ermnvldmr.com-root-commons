#!/usr/bin/env bash
set -euo pipefail

# 1. Path Resolution
SOURCE_PATH="${BASH_SOURCE[0]}"
while [ -L "$SOURCE_PATH" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE_PATH")" >/dev/null 2>&1 && pwd)"
    SOURCE_PATH="$(readlink "$SOURCE_PATH")"
    [[ $SOURCE_PATH != /* ]] && SOURCE_PATH="$DIR/$SOURCE_PATH"
done
ROOT_SHARED="$(cd -P "$(dirname "$SOURCE_PATH")/../.." >/dev/null 2>&1 && pwd)"

if [[ "$ROOT_SHARED" == */.operator/shared ]]; then
    ROOT_CONFIGS="$(cd "$ROOT_SHARED/../.." >/dev/null 2>&1 && pwd)"
else
    ROOT_CONFIGS="$ROOT_SHARED"
fi

export ROOT_SHARED ROOT_CONFIGS
export ROOT_LOCAL="$ROOT_CONFIGS/.operator/local"
export ROOT_ACTIONS_SHARED="$ROOT_SHARED/scripts/actions"
export ROOT_ACTIONS_LOCAL="$ROOT_LOCAL/scripts/actions"

# 2. Warming Environment
# We check if a core library function is already defined.
# This ensures that even in nested calls (where environment variables might be 
# inherited but shell functions are not), the libraries are sourced correctly.
if ! declare -f root_log_info >/dev/null; then
    for lib_dir in "$ROOT_SHARED/scripts/lib" "$ROOT_LOCAL/scripts/lib"; do
        if [[ -d "$lib_dir" ]]; then
            for lib in "$lib_dir"/*.sh; do
                [[ -f "$lib" ]] && source "$lib"
            done
        fi
    done
fi

# 3. Help System (simplified for now)
ACTION_PATH="${1:-}"
if [[ -z "$ACTION_PATH" || "$ACTION_PATH" == "--help" ]]; then
    echo "Usage: root <action_path> [args...]"
    # TODO: Add dynamic help listing
    exit 0
fi
shift

export ROOT_ACTION_PATH="$ACTION_PATH"

# 4. Dispatching
if [[ -f "$ROOT_ACTIONS_LOCAL/$ACTION_PATH" ]]; then
    source "$ROOT_ACTIONS_LOCAL/$ACTION_PATH" "$@"
elif [[ -f "$ROOT_ACTIONS_SHARED/$ACTION_PATH" ]]; then
    source "$ROOT_ACTIONS_SHARED/$ACTION_PATH" "$@"
else
    root_log_error "Unknown action: $ACTION_PATH"
    exit 1
fi
