#!/usr/bin/env bash
action_metadata() {
  cat <<EOF
description: "Configures CrowdSec."
args:
  - NODE: "The node name"
EOF
}

root_require_node "${1:-}"
shift

CONFIG_DIR="$ROOT_NODE_DIR/.operator/configs/crowdsec"

if [[ ! -d "$CONFIG_DIR" ]]; then
    root_log_error "Configuration directory not found: $CONFIG_DIR"
    exit 1
fi

root_log_info "Configuring CrowdSec for $ROOT_NODE..."
if ! command -v cscli >/dev/null 2>&1; then
    root_log_info "CrowdSec not found, installing via official script..."
    curl -s https://install.crowdsec.net | sudo sh
    sudo apt list crowdsec
    sudo apt install crowdsec
fi

root_template_directory "$CONFIG_DIR" /etc/crowdsec

root_log_info "Installing CrowdSec collections..."
sudo cscli hub update 
sudo cscli collections install crowdsecurity/linux
sudo cscli collections install crowdsecurity/traefik

if [[ -f "$CONFIG_DIR/bouncers/crowdsec-firewall-bouncer.yaml.local" ]]; then
    if ! dpkg -l | grep -q crowdsec-firewall-bouncer-iptables; then
        root_log_info "Installing crowdsec-firewall-bouncer-iptables..."
        root_init_install_packages crowdsec-firewall-bouncer-iptables
    fi
fi
root_log_success "Successfully configured crowdsec for $ROOT_NODE."