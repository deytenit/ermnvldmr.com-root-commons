#!/usr/bin/env bash
action_metadata() {
  cat <<EOF
description: "Configures systemd units."
args:
  - NODE: "The node name"
EOF
}

root_require_node "${1:-}"
shift

CONFIG_DIR="$ROOT_NODE_DIR/.operator/configs/systemd"

if [[ ! -d "$CONFIG_DIR" ]]; then
    root_log_error "Configuration directory not found: $CONFIG_DIR"
    exit 1
fi

root_log_info "Deploying and configuring systemd units for $ROOT_NODE..."
if [[ -z "$(ls -A "$CONFIG_DIR" 2>/dev/null)" ]]; then
    root_log_warn "No systemd configuration files found in $CONFIG_DIR."
    exit 0
fi

for template_file in "$CONFIG_DIR"/*; do
    if [[ -f "$template_file" ]]; then
        file_name=$(basename "$template_file")
        dest_file="/etc/systemd/system/$file_name"

        root_log_info "Deploying systemd unit: $file_name -> $dest_file"
        sudo -E bash -c "envsubst < \"$template_file\" > \"$dest_file\""
        
        if [[ "$file_name" == *.service ]]; then
            service_name="${file_name%.service}"
            root_log_info "Enabling and starting service: $service_name"
            sudo systemctl daemon-reload
            root_init_ensure_service_running "$service_name"
            root_log_success "Service $service_name is now active and enabled."
        fi
    fi
done
root_log_success "Successfully configured systemd for $ROOT_NODE."