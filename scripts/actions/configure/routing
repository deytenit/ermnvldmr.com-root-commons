#!/usr/bin/env bash
#
# root setup-routing
# Idempotent routing rules and routes for root.ermnvldmr.com node-level networking.

set -euo pipefail

action_metadata() {
  cat <<EOF
description: "Idempotent routing rules and routes for node-level networking."
args:
  - NODE: "The node name"
EOF
}

root_require_node "${1:-}"
shift

SCRIPT_NAME="setup-routing"

root_log_info "Applying persistent routing configuration for $ROOT_NODE..."

# 1. Runtime IP Forwarding
sudo sysctl -w net.ipv4.ip_forward=1

# 2. IP Rule for mark 0x1 -> table 100
if sudo ip rule show | grep -q 'fwmark 0x1 lookup 100'; then
    root_log_info "IP rule for mark 0x1 already exists."
else
    sudo ip rule add fwmark 0x1 lookup 100 priority 100 || true
    root_log_info "IP rule added for mark 0x1."
fi

# 3. Local route in table 100
if sudo ip route show table 100 2>/dev/null | grep -q 'local default dev lo'; then
    root_log_info "Local route in table 100 already exists."
else
    sudo ip route add local 0.0.0.0/0 dev lo table 100 || true
    root_log_info "Local route added to table 100."
fi

root_log_success "Routing configuration applied successfully."
exit 0

