#!/usr/bin/env bash

action_metadata() {
  cat <<EOF
description: "Configures UFW using envsubst."
args:
  - NODE: "The node name"
EOF
}

root_require_node "${1:-}"
shift

CONFIG_DIR="$ROOT_NODE_DIR/.operator/configs/ufw"

if [[ ! -d "$CONFIG_DIR" ]]; then
    root_log_error "Configuration directory not found: $CONFIG_DIR"
    exit 1
fi

root_log_info "Configuring UFW rules for $ROOT_NODE..."
docker_rules_dir="$CONFIG_DIR/docker"
host_config_dir="$CONFIG_DIR/host"

if [[ -d "$docker_rules_dir" ]]; then
    root_template_ufw "$docker_rules_dir" "$host_config_dir"
else
    root_log_warn "Docker rules directory not found at $docker_rules_dir. Skipping ufw-docker rules."
    if [[ -d "$host_config_dir" ]]; then
        root_template_ufw "$docker_rules_dir" "$host_config_dir"
    fi
fi
root_log_success "Successfully configured ufw for $ROOT_NODE."