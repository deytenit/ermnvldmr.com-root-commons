#!/usr/bin/env bash

action_metadata() {
  cat <<EOF
description: "Configures crontab."
args:
  - NODE: "The node name"
EOF
}

root_require_node "${1:-}"
shift

CONFIG_DIR="$ROOT_NODE_DIR/.operator/configs/cron"
CRONTAB_FILE="$CONFIG_DIR/crontab"

if [[ -f "$CRONTAB_FILE" ]]; then
    root_template_crontab "$CRONTAB_FILE"
else
    root_log_error "Crontab file not found: $CRONTAB_FILE"
    exit 1
fi