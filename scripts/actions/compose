#!/usr/bin/env bash
#
# root compose <node> <action> [--dry-run] [extra_args...]
# Standardized high-level entrypoint for orchestrating docker-compose across a node.

set -euo pipefail

action_metadata() {
  cat <<EOF
description: "Standardized high-level entrypoint for orchestrating docker-compose across a node."
args:
  - NODE: "The node name"
  - ACTION: "The action to perform (up, down, restart)"
  - EXTRA_ARGS: "Optional extra arguments, such as --dry-run"
EOF
}

# --- Context established by root entrypoint ---
# ROOT_CONFIGS is the repo root.
# Logging functions are available.

# --- Node Context ---
root_require_node "${1:-}"
shift

# --- Parse Arguments ---
ACTION="${1:-}"
shift || true

DRY_RUN=false
EXTRA_ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        *)
            EXTRA_ARGS+=("$1")
            shift
            ;;
    esac
done

if [[ -z "$ACTION" ]]; then
    root_log_error "Usage: root compose <node> <action (up|down|restart)> [--dry-run] [extra_args...]"
    exit 1
fi

# --- Helper Functions ---
run_compose() {
    local compose_file="$1"
    local action="$2"
    local dir_path="$(dirname "$compose_file")"
    local service_name="$(basename "$dir_path")"
    
    # If the dir is the node root, name it "node-infra"
    if [[ "$dir_path" == "$ROOT_NODE_DIR" ]]; then
        service_name="node-infra"
    fi

    root_log_info "Executing $action on $service_name..."
    
    local cmd=(docker compose -f "$compose_file" "$action")
    if [[ "$action" == "up" ]]; then
        cmd+=("-d")
    fi
    cmd+=("${EXTRA_ARGS[@]}")

    if [[ "$DRY_RUN" == "true" ]]; then
        root_log_info "[DRY-RUN] ${cmd[*]}"
    else
        (cd "$dir_path" && "${cmd[@]}")
    fi
}

# --- Discovery ---
services=()
for entry in "$ROOT_NODE_DIR"/*; do
    [[ ! -d "$entry" ]] && continue
    dir_name="$(basename "$entry")"
    
    # Exclude @tier directories, .operator and root (handled separately)
    [[ "$dir_name" == @tier* ]] && continue
    [[ "$dir_name" == ".operator" ]] && continue
    [[ "$dir_name" == "root" ]] && continue
    
    if [[ -f "$entry/docker-compose.yml" ]]; then
        services+=("$entry/docker-compose.yml")
    fi
done

# Sort services alphabetically for stable order
sorted_services=()
if [[ "${#services[@]}" -gt 0 ]]; then
    mapfile -t sorted_services < <(printf "%s\n" "${services[@]}" | sort)
fi

# --- Orchestration ---
if [[ "$ACTION" == "down" ]]; then
    # REVERSE ORDER: Others -> Root -> Node Infra
    # Reverse sorted_services for shutdown
    if [[ "${#sorted_services[@]}" -gt 0 ]]; then
        mapfile -t sorted_services < <(printf "%s\n" "${sorted_services[@]}" | tac)
    fi

    for s in "${sorted_services[@]}"; do
        run_compose "$s" "$ACTION"
    done
    
    if [[ -f "$ROOT_NODE_DIR/root/docker-compose.yml" ]]; then
        run_compose "$ROOT_NODE_DIR/root/docker-compose.yml" "$ACTION"
    fi
    
    if [[ -f "$ROOT_NODE_DIR/docker-compose.yml" ]]; then
        run_compose "$ROOT_NODE_DIR/docker-compose.yml" "$ACTION"
    fi
else
    # FORWARD ORDER: Node Infra -> Root -> Others
    if [[ -f "$ROOT_NODE_DIR/docker-compose.yml" ]]; then
        run_compose "$ROOT_NODE_DIR/docker-compose.yml" "$ACTION"
    fi
    
    if [[ -f "$ROOT_NODE_DIR/root/docker-compose.yml" ]]; then
        run_compose "$ROOT_NODE_DIR/root/docker-compose.yml" "$ACTION"
    fi
    
    for s in "${sorted_services[@]}"; do
        run_compose "$s" "$ACTION"
    done
fi

root_log_success "Successfully orchestrated $ACTION for node $ROOT_NODE."
