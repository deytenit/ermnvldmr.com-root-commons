#!/bin/bash
#
# sync-remote <NODE> <TELEGRAM_BOT_URL> [TELEGRAM_PROXY]
# Adds changes in the <NODE> directory, commits them to a sync/<NODE> branch,
# rebases onto origin/trunk, and force-pushes. Notifies via Telegram.

action_metadata() {
  cat <<EOF
description: "Adds changes in the node directory, commits them, rebases onto origin/trunk, and force-pushes."
args:
  - NODE: "The node name"
  - TELEGRAM_BOT_URL: "The Telegram Bot URL for notifications"
  - TELEGRAM_PROXY: "(Optional) The proxy to use for Telegram notifications"
EOF
}

# --- Script-specific settings ---
SCRIPT_NAME="sync-remote"

root_require_node "${1:-}"
shift

TELEGRAM_BOT_URL="${1:-}"
TELEGRAM_PROXY="${2:-}"

if [[ -z "$TELEGRAM_BOT_URL" ]]; then
    root_log_error "Usage: $0 <NODE> <TELEGRAM_BOT_URL> [TELEGRAM_PROXY]"
    exit 64
fi

# --- Setup Error Handling ---
TELEGRAM_TITLE_PREFIX="Annual Remote Sync"
root_core_setup_error_trap "$TELEGRAM_TITLE_PREFIX" "$TELEGRAM_BOT_URL" "$ROOT_NODE" "$TELEGRAM_PROXY"

root_log_info "Starting remote sync for node: $ROOT_NODE"

# --- Check if shared repository itself has uncommitted changes ---
if [ -n "$(git -C "$ROOT_SHARED" status --porcelain 2>/dev/null)" ]; then
    root_log_error "Shared repository at $ROOT_SHARED has uncommitted changes. Aborting sync."
    exit 1
fi

# --- Ensure that the NODE directory exists ---
# ROOT_NODE_DIR is set by root_require_node
if [ ! -d "$ROOT_NODE_DIR" ]; then
    # This error will be caught by the trap and a Telegram message sent.
    root_log_error "Directory '$ROOT_NODE_DIR' does not exist. Cannot sync."
    exit 1 # Exit, trap will handle notification
fi
root_log_info "Node directory '$ROOT_NODE_DIR' found."

# --- Git Operations ---
# cd to REPO_ROOT (ROOT_CONFIGS)
cd "$ROOT_CONFIGS"

BRANCH_NAME="sync/$ROOT_NODE"
COMMIT_TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')

# Add these variables for bot identity:
export GIT_AUTHOR_NAME="Adam Jensen [bot]"
export GIT_AUTHOR_EMAIL="adam@ermnvldmr.com"
export GIT_COMMITTER_NAME="Adam Jensen [bot]"
export GIT_COMMITTER_EMAIL="adam@ermnvldmr.com"

# Create the "sync/{NODE}" branch if it doesn't exist and check out
root_log_info "Switching to branch '$BRANCH_NAME'..."
if ! git rev-parse --verify "$BRANCH_NAME" > /dev/null 2>&1; then
    root_log_info "Branch '$BRANCH_NAME' does not exist. Creating and checking out."
    git checkout -b "$BRANCH_NAME"
else
    root_log_info "Branch '$BRANCH_NAME' exists. Checking out."
    git checkout "$BRANCH_NAME"
fi

# --- Stage Changes ---
root_log_info "Staging changes in '$ROOT_NODE' directory..."
git add "$ROOT_NODE" 

root_log_info "Updating submodules to latest remote versions..."
git submodule update --remote --recursive
git add .operator/shared

# Check if there are any changes staged for commit
if ! git diff --cached --quiet; then # --quiet to suppress output, rely on exit code
    root_log_info "Changes detected. Committing..."
    git commit -m "[$ROOT_NODE] Auto-commit: $COMMIT_TIMESTAMP"
    root_log_info "Commit successful."
else
    root_log_info "No changes to commit (Node and Submodule pointers are already up-to-date)."
fi

# Attempt to rebase onto origin/trunk
root_log_info "Fetching origin/trunk..."
git fetch origin trunk
root_log_info "Rebasing '$BRANCH_NAME' onto origin/trunk..."
if ! git rebase origin/trunk; then
    # Error will be caught by trap, but specific message is good.
    root_log_error "Rebase conflict detected for branch '$BRANCH_NAME' onto origin/trunk. Aborting rebase. Manual intervention required."
    git rebase --abort # Clean up failed rebase
    # Trap will send a generic error, but we can send a more specific one here too.
    root_core_telegram_error "$TELEGRAM_TITLE_PREFIX" "$TELEGRAM_BOT_URL" "Rebase conflict. Manual intervention required. Rebase aborted." "$ROOT_NODE" "$TELEGRAM_PROXY"
    exit 1
fi
root_log_info "Rebase successful."

# Update submodules to match the rebased state
root_log_info "Updating submodules (init + recursive)..."
if ! git submodule update --init --recursive; then
    root_log_error "Failed to update submodules after rebase. Manual intervention may be required."
    exit 1
fi
root_log_info "Submodules updated successfully."

# Push the changes to the remote repository
root_log_info "Pushing changes for branch '$BRANCH_NAME' to origin (force-with-lease)..."
if git push --force-with-lease origin "$BRANCH_NAME"; then
    root_log_success "Successfully pushed '$BRANCH_NAME' to origin."
    root_core_telegram_success "$TELEGRAM_TITLE_PREFIX" "$TELEGRAM_BOT_URL" "Sync to remote branch '$BRANCH_NAME' completed successfully." "$ROOT_NODE" "$TELEGRAM_PROXY"
else
    # Error will be caught by trap.
    root_log_error "Failed to push '$BRANCH_NAME' to origin."
    # Trap will send a generic error.
    root_core_telegram_error "$TELEGRAM_TITLE_PREFIX" "$TELEGRAM_BOT_URL" "Failed to push to remote branch '$BRANCH_NAME'." "$ROOT_NODE" "$TELEGRAM_PROXY"
    exit 1
fi

root_log_success "Remote sync completed for node: $ROOT_NODE."
