#!/bin/bash
#
# sync-tiers <NODE> <TELEGRAM_BOT_URL>
# Runs restic backup (one-shot) using the docker-compose file in the node's docker-compose.yml directory.
# Sends Telegram notifications on success/failure. Mirrors the style & helpers of sync-tiers.

action_metadata() {
  cat <<EOF
description: "Runs restic backup (one-shot) using the docker-compose file in the node's docker-compose.yml directory."
args:
  - NODE: "The node name"
  - TELEGRAM_BOT_URL: "The Telegram Bot URL for notifications"
EOF
}

SCRIPT_NAME="restic-backup"

root_require_node "${1:-}"
shift

TELEGRAM_BOT_URL="${1:-}"

if [[ -z "$TELEGRAM_BOT_URL" ]]; then
    root_log_error "Usage: $0 <NODE> <TELEGRAM_BOT_URL>"
    exit 64
fi

# --- Setup Error Handling ---
TELEGRAM_TITLE_PREFIX="Restic Host Backup"
root_core_setup_error_trap "$TELEGRAM_TITLE_PREFIX" "$TELEGRAM_BOT_URL" "$ROOT_NODE"

root_log_info "Starting restic backup for node: $ROOT_NODE"

# --- Ensure that the NODE directory and compose file exist ---
COMPOSE_FILE_PATH="$ROOT_NODE_DIR/docker-compose.yml"

RESTIC_TAG="com-ermnvldmr-root-$ROOT_NODE"

if [ ! -d "$ROOT_NODE_DIR" ]; then
    root_log_error "Node directory '$ROOT_NODE_DIR' does not exist. Cannot run restic backup."
    exit 1
fi
root_log_info "Node directory '$ROOT_NODE_DIR' found."

if [ ! -f "$COMPOSE_FILE_PATH" ]; then
    root_log_error "Docker Compose file '$COMPOSE_FILE_PATH' not found. Cannot run restic backup."
    exit 1
fi
root_log_info "Compose file '$COMPOSE_FILE_PATH' found."

# --- Helper to run restic inside compose ---
run_restic() {
    local cmd="$*"
    root_log_info "Running restic: $cmd"
    if (cd "$ROOT_NODE_DIR" && docker compose run --rm restic $cmd); then
        return 0
    else
        return 1
    fi
}

# --- Ensure restic repo is initialized (do this only once) ---
root_log_info "Checking restic repository availability..."
if run_restic snapshots >/dev/null 2>&1; then
    root_log_info "Restic repository appears initialized and reachable."
else
    root_log_info "Restic repository not initialized or unreachable; attempting 'restic init'..."
    if run_restic init; then
        root_log_info "Restic repository initialized."
    else
        root_log_error "Failed to initialize restic repository."
        root_core_telegram_error "$TELEGRAM_TITLE_PREFIX" "$TELEGRAM_BOT_URL" "restic init failed" "$ROOT_NODE"
        exit 1
    fi
fi

# --- Run the backup (only the mounted tier data) ---
root_log_info "Starting backup of $ROOT_TIER1 and $ROOT_TIER2 (read-only mounts in compose) ..."
if run_restic backup /data/@tier1 /data/@tier2 --host "$ROOT_NODE" --tag "$RESTIC_TAG" --compression auto; then
    root_log_info "Backup command completed successfully."
else
    root_log_error "restic backup failed."
    root_core_telegram_error "$TELEGRAM_TITLE_PREFIX" "$TELEGRAM_BOT_URL" "restic backup failed" "$ROOT_NODE"
    exit 1
fi

# --- Run retention policy (forget + prune). Tune keep values as you like. ---
# Example retention policy: keep daily 7, weekly 4, monthly 12
root_log_info "Applying retention policy (forget + prune)..."
if run_restic forget --prune --keep-daily 7 --keep-weekly 4 --keep-monthly 12; then
    root_log_info "Retention policy applied successfully."
else
    root_log_error "restic forget/prune failed."
    root_core_telegram_error "$TELEGRAM_TITLE_PREFIX" "$TELEGRAM_BOT_URL" "restic forget/prune failed" "$ROOT_NODE"
    exit 1
fi

# --- Success notification ---
root_log_success "Restic backup completed successfully for node: $ROOT_NODE"
root_core_telegram_success "$TELEGRAM_TITLE_PREFIX" "$TELEGRAM_BOT_URL" "Restic backup + retention succeeded for node: $ROOT_NODE" "$ROOT_NODE"
exit 0

