#!/usr/bin/env bash
#
# extract-traefik-certs <node> <acme_json_path> <dest_dir>
# Extracts Traefik v3 acme.json certificates into fullchain.pem and privkey.pem
# uses ldez/traefik-certs-dumper via Docker

set -euo pipefail
IFS=$'\n\t'

action_metadata() {
  cat <<EOF
description: "Extracts Traefik v3 acme.json certificates into fullchain.pem and privkey.pem"
args:
  - NODE: "The node name"
  - SOURCE_ACME: "path to acme.json"
  - DEST_DIR: "destination directory"
EOF
}

# --- Initialize ---
root_require_node "${1:-}"
shift

# --- Parse arguments ---
SOURCE_ACME="${1:-}"
DEST_DIR="${2:-}"

if [[ -z "$SOURCE_ACME" || -z "$DEST_DIR" ]]; then
    root_log_error "Usage: root utils/extract-traefik-certs <node> <path_to_acme.json> <destination_directory>"
    exit 64
fi

# --- Validation ---
if [[ ! -f "$SOURCE_ACME" ]]; then
    root_log_error "Source file not found: $SOURCE_ACME"
    exit 1
fi

# Convert to absolute paths for Docker mounting
ABS_SOURCE="$(realpath "$SOURCE_ACME")"
SOURCE_DIR="$(dirname "$ABS_SOURCE")"
SOURCE_FILE="$(basename "$ABS_SOURCE")"

mkdir -p "$DEST_DIR"
ABS_DEST="$(realpath "$DEST_DIR")"

root_log_info "Extracting certificates for node $ROOT_NODE..."
root_log_info "  Source: $ABS_SOURCE"
root_log_info "  Destination: $ABS_DEST"

# --- Execute Dumper via Docker ---
# We mount the source directory and the destination directory
# Traefik v3 requires the --version v3 flag
docker run --rm \
    -v "$SOURCE_DIR:/data" \
    -v "$ABS_DEST:/output" \
    ldez/traefik-certs-dumper:v2.9.3 \
    file --version v3 \
    --source "/data/$SOURCE_FILE" \
    --dest /output \
    --domain-subdir=true \
    --crt-name=fullchain \
    --crt-ext=.pem \
    --key-name=privkey \
    --key-ext=.pem

# --- Fix Permissions ---
# Docker creates files as root; we want them accessible but secure.
# If you are running this as part of your noroot setup, 
# you might want to chown these to your specific user.
root_log_info "Setting secure permissions (600) on extracted keys..."
find "$ABS_DEST" -type f -name "*.pem" -exec chmod 600 {} +

root_log_success "✅ Certificates extracted successfully!"
root_log_info "Structure created at $DEST_DIR:"
root_log_info "  └── [domain]/"
root_log_info "      ├── fullchain.pem"
root_log_info "      └── privkey.pem"
